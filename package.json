{
  "name": "vigilantcode-vs",
  "publisher": "Darkace",
  "publisherID": "Darkace",
  "displayName": "VigilantCode VS",
  "icon": "images/icon.png",
  "description": "VigilantCode VS scans your code for vulnerabilities before deployment, ensuring that your code is secure and free from known vulnerabilities. It uses the Gemini API (Google Generative AI) to analyze your code and provide recommendations for fixing any issues found.",

  "version": "0.0.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vigilantcode.analyzeCode"
  ],
  "main": "./VigilantCode.js",
  "contributes": {
    "commands": [
      {
        "command": "vigilantcode.analyzeCode",
        "title": "Analyze code with VigilantCode"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vigilantcode.analyzeCode",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.98.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.21.0",
    "vscode": "^1.0.0"
   
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "axios": "^1.8.4",
    "dotenv": "^16.5.0",
    "marked": "^15.0.7",
    "openai": "^4.89.0"
     
  }
}
